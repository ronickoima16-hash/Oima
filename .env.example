# ── Telegram ──────────────────────────────────────────────
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890

# The Telegram account where the bot sends YOU notifications
# (can be your own username or a dedicated bot token)
NOTIFY_CHAT_ID=your_telegram_user_id

# ── Binance ───────────────────────────────────────────────
# Futures API keys — use TESTNET keys first!
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Set to "true" for testnet, "false" for live trading
BINANCE_TESTNET=true

# ── Signal Sources ────────────────────────────────────────
# Comma-separated channel usernames or numeric IDs
# For private channels, use the numeric ID (e.g. -1001234567890)
SIGNAL_CHANNELS=CryptoDevilVip,-1001234567890
